{
  "name": "@marqvision/mds-v2",
  "version": "2.0.0",
  "description": "Common design system for MarqVision web applications",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "eslintConfig": {
    "rules": {
      "no-restricted-imports": [
        "error",
        {
          "patterns": [
            "opscc-ui-web*",
            "contents*",
            "brand*",
            "folio*",
            "mds*",
            "shared*"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.1.7",
    "@storybook/addon-links": "^10.1.7",
    "@storybook/react": "^10.1.7",
    "@storybook/react-vite": "^10.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.10",
    "html-react-parser": "^5.1.12",
    "jotai": "^2.12.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.1.7",
    "vite-plugin-checker": "^0.11.0"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0"
  }
}
