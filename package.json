{
  "name": "@marqvision/mds-v2",
  "version": "2.0.0",
  "description": "Common design system for MarqVision web applications",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "chromatic": "chromatic --exit-zero-on-changes --only-changed"
  },
  "eslintConfig": {
    "rules": {
      "no-restricted-imports": [
        "error",
        {
          "patterns": [
            "opscc-ui-web*",
            "contents*",
            "brand*",
            "folio*",
            "mds*",
            "shared*"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "chromatic": "^6.24.1",
    "prop-types": "^15.8.1",
    "storybook": "^10.2.8"
  }
}
